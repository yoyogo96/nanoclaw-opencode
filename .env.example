# OpenCode provider API keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Assistant personality
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false

# Container settings
CONTAINER_IMAGE=nanoclaw-agent:latest
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5

# OpenCode model override (optional)
OPENCODE_MODEL=anthropic/claude-sonnet-4-20250514

# Timezone (auto-detected if not set)
# TZ=Asia/Seoul

# Channel credentials (add as needed)
# WHATSAPP_PHONE_NUMBER=...
# TELEGRAM_BOT_TOKEN=...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=...
# SLACK_APP_TOKEN=...
# GMAIL_CLIENT_ID=...
# GMAIL_CLIENT_SECRET=...
